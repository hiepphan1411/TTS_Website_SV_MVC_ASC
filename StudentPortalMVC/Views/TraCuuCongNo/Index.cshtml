
@{
    ViewBag.Title = "Tra cứu công nợ";
}

@section styles {
    <link rel="stylesheet" href="~/Content/css/tra-cuu-cong-no.css" />
}

<div class="container-lg d-flex flex-column gap-3 py-4">
    <!-- Page Header -->
    <div class="header-section">
        <div class="header-title">Tra cứu công nợ</div>
    </div>
    <div class="card-access shadow-sm">
        <div class="card-body">
            <div class="card-head d-flex justify-content-between">
                <div class="card-title">Các khoản chưa thanh toán</div>
                <div class="btn-group btn-group-sm">
                    <button class="btn-payment" onclick="window.location.href='@Url.Action("Index", "ThanhToanTrucTuyen")'">
                        Chuyển đến trang thanh toán
                    </button>
                </div>
            </div>
            <!-- Unpaid Fees Section -->
            <div class="unpaid-section">
                <div class="unpaid-content">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width: 50px">STT</th>
                                <th>Loại khoản thu</th>
                                <th>Nội dung</th>
                                <th>Năm học / Học kỳ</th>
                                <th class="text-end">Số tiền</th>
                                <th class="text-center">Hạn thanh toán</th>
                            </tr>
                        </thead>
                        <tbody id="unpaid-table-body"></tbody>
                    </table>
                    <div class="summary-section">
                        <h3 class="summary-text">Các khoản chưa thanh toán</h3>
                        <span class="summary-amount" id="unpaid-total-display">0₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-access shadow-sm">
        <div class="card-body">
            <div class="card-head d-flex justify-content-between">
                <div class="card-title">Danh sách khoản thu</div>
                <div class="semester-filter">
                    <label>Học Kỳ</label>
                    <select>
                        <option>Tất cả</option>
                        <option>2025 - 2026 (HK2)</option>
                        <option>2025 - 2026 (HK1)</option>
                        <option>2024 - 2025 (HK2)</option>
                    </select>
                </div>
            </div>
            <!-- Tabs Container  -->
            <div class="tabs-container">
                <div class="tabs-nav">
                    <button class="tab-btn active" data-tab="fees">
                        Khoản thu khác
                    </button>
                    <button class="tab-btn" data-tab="tuition">
                        Học phí
                    </button>
                    <button class="tab-btn" data-tab="courses">
                        Môn học đăng ký
                    </button>
                    <button class="tab-btn"
                            data-tab="deductions">
                        Danh sách khấu trừ
                    </button>
                </div>

                <!-- Tab: Khoản thu khác -->
                <div id="fees" class="tab-content active">
                    <div class="summary-section">
                        <span class="summary-text">Tổng công nợ:</span>
                        <span class="summary-amount">1.000.000₫</span>
                    </div>

                    <div class="data-table-wrapper mt-3">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width: 50px">STT</th>
                                    <th>Năm học</th>
                                    <th>Tên đợt</th>
                                    <th>Mã khoản thu</th>
                                    <th>Tên khoản thu khác</th>
                                    <th class="text-end">Mức nộp</th>
                                    <th class="text-center">Bắt buộc</th>
                                    <th class="text-center">Ngày nộp</th>
                                    <th class="text-end">Số tiền nộp</th>
                                    <th class="text-end">Công nợ</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>

                        <div class="pagination-wrapper">
                            <div class="pagination-info">1 - 2 của 2</div>
                            <div class="pagination-controls">
                                <button class="pagination-btn" disabled>
                                    <i class="fas fa-angle-double-left"></i>
                                </button>
                                <button class="pagination-btn" disabled>
                                    <i class="fas fa-angle-left"></i>
                                </button>
                                <select class="pagination-btn">
                                    <option>1</option>
                                </select>
                                <button class="pagination-btn" disabled>
                                    <i class="fas fa-angle-right"></i>
                                </button>
                                <button class="pagination-btn" disabled>
                                    <i class="fas fa-angle-double-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

