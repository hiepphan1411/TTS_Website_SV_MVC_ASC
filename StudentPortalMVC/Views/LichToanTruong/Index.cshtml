
@{
    ViewBag.Title = "Lịch toàn trường";
}

@section styles {
    <link rel="stylesheet" href="~/Content/css/lich-toan-truong.css" />
}

<div class="container-lg d-flex flex-column gap-3 py-4">

    <div class="page-header">
        <h1 class="page-title">Lịch toàn trường</h1>
        <p class="page-subtitle">Xem lịch học và các sự kiện toàn trường</p>
    </div>

    <div class="search-section">
        <h3 class="header-title">Tra cứu lịch</h3>
        <form class="search-form">
            <div class="form-group">
                <label>Chọn trình độ đào tạo <span class="required">*</span></label>
                <select class="form-select">
                    <option>Đại học - Tín chỉ</option>
                    <option>Cao đẳng</option>
                    <option>Sau đại học</option>
                </select>
            </div>

            <div class="form-group">
                <label>Chọn học kỳ <span class="required">*</span></label>
                <select class="form-select">
                    <option>HK1 (2025-2026)</option>
                    <option>HK2 (2024-2025)</option>
                    <option>HK1 (2024-2025)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Chọn khoa <span class="required">*</span></label>
                <select class="form-select">
                    <option>Khoa Pháp luật hình sự</option>
                    <option>Khoa Luật dân sự</option>
                    <option>Khoa Luật kinh tế</option>
                </select>
            </div>

            <div class="form-group">
                <label>Lớp học</label>
                <select class="form-select">
                    <option>Khoa Pháp luật hình sự</option>
                    <option>Lớp A1</option>
                    <option>Lớp A2</option>
                </select>
            </div>

            <div class="form-group" style="grid-column: 1 / -1">
                <label>Mã môn / Tên môn học</label>
                <input type="text"
                       class="form-control"
                       placeholder="Luật hình sự 1" />
            </div>

            <div class="form-actions">
                <button type="button" class="btn-search">Xem lịch thi</button>
                <button type="button" class="btn-view-schedule">
                    Xem lịch học
                </button>
            </div>
        </form>
    </div>

    <div class="schedule-list-section">
        <h3 class="header-title">Lịch tra cứu</h3>
        <div class="schedule-list-content" data-url="@Url.Action("GetDataLichToanTruong", "LichToanTruong")"></div>

        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị 1-5 trong tổng số 20 môn học/học phần
            </div>
            <ul class="pagination justify-content-center align-items-center">
                <li class="page-item">
                    <a class="page-step" href="#">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item active">
                    <a class="page-link rounded-circle" href="#">1</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle" href="#">2</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle" href="#">3</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle" href="#">4</a>
                </li>
                <li class="page-item">
                    <a class="page-step" href="#">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/js/lich-toan-truong.js"></script>
}