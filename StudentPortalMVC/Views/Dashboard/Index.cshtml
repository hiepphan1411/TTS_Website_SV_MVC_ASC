@{
    ViewBag.Title = "Dashboard";
}

@section styles {
    <link rel="stylesheet" href="~/Content/css/dashboard.css" />
}


<div class="container-lg d-flex flex-column gap-3 pt-4">
    <!-- Highest priority -->
    <div class="row g-3">
        <!-- student information -->
        <div class="col-12 col-md-5 col-xl-3">
            <div class="student-card text-center h-100">
                <div class="avatar-card mx-auto"></div>
                <h6 class="fw-bold mb-0">Asc Test</h6>
                <small class="fw-semibold text-muted">2552010678</small>

                <div class="info-row">
                    <span class="row-title">Ngày sinh:</span>
                    <span class="fw-semibold row-content">01/01/2008</span>
                </div>
                <div class="info-row">
                    <span class="row-title">Khóa học:</span>
                    <span class="fw-semibold row-content">Khóa 2025</span>
                </div>
                <div class="info-row">
                    <span class="row-title">Lớp học:</span>
                    <span class="fw-semibold row-content">D.14.22.03</span>
                </div>
                <div class="info-row">
                    <span class="row-title">Ngành:</span>
                    <span class="fw-semibold row-content">Tài chính - Ngân hàng</span>
                </div>

                <a href="../ThongTinSinhVien"
                   class="fw-bold profile-link mt-3 d-inline-block">
                    Xem chi tiết hồ sơ
                </a>
            </div>
        </div>

        <!-- Lịch hôm nay -->
        <div class="col-12 col-md-7 col-xl-7">
            <div class="schedule-card d-flex flex-column h-100">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <span class="card-title">
                            Lịch hôm nay
                        </span>
                        <small class="fw-semibold text-muted d-block">Thứ Tư, 13 Tháng 01, 2026</small>
                    </div>
                    <div class="badge-group flex-wrap">
                        <span class="badge bg-primary-subtle text-primary border border-primary">
                            1 Lịch học
                        </span>
                        <span class="badge bg-warning-subtle text-warning border border-warning">
                            1 Lịch thi
                        </span>
                    </div>
                </div>

                <div class="schedule-item-border">
                    <!-- item 1 -->
                    <div class="schedule-item blue">
                        <div class="time-box flex-shrink-0">
                            <span>Tiết</span>
                            <strong>1-3</strong>
                        </div>

                        <div class="schedule-info">
                            <p class="fw-bold" style="color: #2a4591; word-break: break-all; font-size: 13px;">
                                DHKTPM18A-420300314705
                            </p>
                            <div class="fw-semibold" style="color: #2865eb">
                                Thực tập doanh nghiệp
                            </div>
                            <div class="meta">
                                <i class="fa-solid fa-clock"></i>
                                6h30 - 9h10 &nbsp; • &nbsp;
                                <i class="fa-solid fa-location-dot"></i>
                                Phòng A203
                            </div>
                        </div>

                        <div class="teacher align-items-center">
                            Giảng viên<br />
                            <strong>TS. Nguyễn Văn A</strong>
                        </div>
                    </div>

                    <!-- item 2 -->
                    <div class="schedule-item orange">
                        <div class="time-box flex-shrink-0">
                            <span>Tiết</span>
                            <strong>7-9</strong>
                        </div>

                        <div class="schedule-info">
                            <p class="fw-bold" style="color: #7c2d12; word-break: break-all; font-size: 13px;">
                                DHKTPM18A-420300314705
                            </p>
                            <div class="fw-semibold" style="color: #fb933e">
                                Thực tập doanh nghiệp
                            </div>
                            <div class="meta">
                                <i class="fa-solid fa-clock"></i>
                                12h30 - 15h &nbsp; • &nbsp;
                                <i class="fa-solid fa-location-dot"></i>
                                Phòng A403
                            </div>
                        </div>

                        <div class="teacher">
                            Giảng viên<br />
                            <strong>ThS. Trần Văn B</strong>
                        </div>
                    </div>
                </div>
                <div class="text-end mt-auto">
                    <a href="../LichTheoTuan"
                       class="profile-link course-code">
                        Xem chi tiết
                    </a>
                </div>
            </div>
        </div>

        <!-- RIGHT: SUMMARY -->
        <div class="col-12 col-xl-2">
            <div class="sumary h-100">
                <a href="../LichTheoTuan" class="text-decoration-none sumary-link">
                    <div class="summary-card blue">
                        <div class="summary-title-study">
                            <i class="fas fa-book-open" style="font-size: 20px"></i>
                            <p>HỌC TẬP</p>
                        </div>
                        <div class="summary-desc-study blue">Lịch học trong tuần</div>
                        <div style="display: flex">
                            <p class="summary-value-study">2</p>
                            <p style="font-size: 11px; color: var(--primary-blue); font-style: italic; margin-top: 14px;">
                                môn học
                            </p>
                        </div>
                    </div>
                </a>
                <a href="../LichTheoTuan" class="text-decoration-none sumary-link">
                    <div class="summary-card orange">
                        <div class="summary-title-exam">
                            <i class="fa-solid fa-pen-fancy" style="font-size: 20px"></i>
                            <p>KỲ THI</p>
                        </div>
                        <div class="summary-desc-exam orange">Lịch thi sắp tới</div>
                        <div style="display: flex">
                            <p class="summary-value-exam">1</p>
                            <p style="font-size: 11px; color: var(--warning-orange); font-style: italic; margin-top: 14px;">
                                môn học
                            </p>
                        </div>
                    </div>
                </a>
                <a href="../GhiChuNhacNho" class="text-decoration-none sumary-link">
                    <div class="summary-card gray">
                        <div class="summary-title-remind">
                            <i class="fa-solid fa-bell" style="font-size: 20px"></i>
                            <p>NHẮC NHỞ</p>
                        </div>
                        <div class="summary-desc-remind gray">Nhắc nhở mới</div>
                        <div style="display: flex">
                            <p class="summary-value-exam">0</p>
                            <p style="font-size: 11px; color: var(--primary-gray); font-style: italic; margin-top: 14px;">
                                chưa xem
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Function Container -->
    <div class="card-access shadow-sm">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="card-title mb-0">Truy cập nhanh</span>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-toggle btn-compact active">
                        <i class="fas fa-compress-alt me-1"></i> Gần đây
                    </button>
                    <button class="btn btn-toggle btn-expanded">
                        <i class="fas fa-th me-1"></i> Tất cả
                    </button>
                </div>
            </div>

            <!-- Compact View -->
            <div class="quick-access-compact">
                <button class="card-access-quick shadow-sm"
                        onclick="window.location.href = '../KetQuaHocTap'">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="quick-access-icon rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="background-color: var(--primary-blue)">
                            <i class="fas fa-chart-line text-white"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold small" style="font-size: 14px">
                                Kết quả học tập
                            </h6>
                            <p class="mb-0 text-muted" style="font-size: 12px">
                                5 phút trước
                            </p>
                        </div>
                    </div>
                </button>

                <button class="card-access-quick shadow-sm"
                        onclick="window.location.href = '../DangKyHocPhan'">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="quick-access-icon rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="background-color: var(--primary-blue)">
                            <i class="fas fa-book text-white"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold small" style="font-size: 14px">
                                Đăng ký học phần
                            </h6>
                            <p class="mb-0 text-muted" style="font-size: 12px">
                                30 phút trước
                            </p>
                        </div>
                    </div>
                </button>

                <button class="card-access-quick shadow-sm"
                        onclick="window.location.href = '../LichTheoTuan'">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="quick-access-icon rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="background-color: var(--primary-blue)">
                            <i class="fas fa-calendar-alt text-white"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold small" style="font-size: 14px">
                                Lịch theo tuần
                            </h6>
                            <p class="mb-0 text-muted" style="font-size: 12px">
                                1 giờ trước
                            </p>
                        </div>
                    </div>
                </button>

                <button class="card-access-quick shadow-sm"
                        onclick="window.location.href = '../TraCuuCongNo'">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="quick-access-icon rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="background-color: var(--primary-blue)">
                            <i class="fas fa-credit-card text-white"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold small" style="font-size: 14px">
                                Tra cứu công nợ
                            </h6>
                            <p class="mb-0 text-muted" style="font-size: 12px">
                                Hôm qua
                            </p>
                        </div>
                    </div>
                </button>

                <button class="card-access-quick shadow-sm"
                        onclick="window.location.href = '../KhaoSatSuKien'">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="quick-access-icon rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="background-color: var(--primary-blue)">
                            <i class="fas fa-id-card text-white"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold small" style="font-size: 14px">
                                Khảo sát
                            </h6>
                            <p class="mb-0 text-muted" style="font-size: 12px">
                                Hôm qua
                            </p>
                        </div>
                    </div>
                </button>
            </div>

            <!-- Expanded View - Auto Grid Layout -->
            <div class="quick-access-expanded d-none">
                <div class="quick-access-grid">
                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../LichTheoTuan'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Lịch theo tuần</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../DangKyHocPhan'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-book"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Đăng ký học phần</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../KetQuaHocTap'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Kết quả học tập</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../TraCuuCongNo'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-credit-card"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Tra cứu công nợ</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../ThanhToanTrucTuyen'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">
                            Thanh toán trực tuyến
                        </h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../PhieuThuTongHop'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">
                            Phiếu thu tổng hợp
                        </h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../LichTheoTienDo'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-list-check"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Lịch theo tiến độ</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../LichTheoTuan'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-pencil-alt"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Lịch theo tuần</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../GhiChuNhacNho'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-bell"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Nhắc nhở</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../KhaoSatSuKien'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-id-card"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Khảo sát</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../HoSoSinhVien'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-folder"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Hồ sơ điện tử</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../HocBong'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Học bổng</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../DangKyNoiTru'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-bed"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Đăng ký nội trú</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../DeXuatBieuMau'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-file-signature"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Đề xuất biểu mẫu</h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="
                    window.location.href = '../ThongTinSinhVien'
                  ">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">
                            Thông tin sinh viên
                        </h6>
                    </div>

                    <div class="quick-access-item-expanded"
                         role="button"
                         onclick="window.location.href = '../LienHeGopY'">
                        <div class="quick-access-icon-simple">
                            <i class="fas fa-comments"></i>
                        </div>
                        <h6 class="mb-0 small fw-semibold mt-2">Góp ý</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="grid-2-cols section-info">
        <div class="card border-0">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="card-title">Tiến độ học tập</span>
                <span class="progress-percentage-header">83%</span>
            </div>
            <div class="card-body">
                <!-- GPA and Progress Container -->
                <div class="gpa-progress-container">
                    <!-- GPA Display Card -->
                    <div class="gpa-display-card rounded-4 text-white p-4">
                        <div class="gpa-label mb-2">GPA Tích lũy</div>
                        <div class="gpa-number fw-bold mb-2">3.62</div>
                        <span class="badge gpa-badge">Xếp loại Giỏi</span>
                    </div>

                    <!-- Progress and Credit Section -->
                    <div class="progress-credit-section">
                        <!-- Progress Bar Section -->
                        <div class="progress-section mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="progress-label">Tín chỉ tích lũy</small>
                                <span class="progress-value">135/162</span>
                            </div>
                            <div class="progress-bar-wrapper">
                                <div class="progress-bar-fill" style="width: 83%"></div>
                            </div>
                        </div>

                        <!-- Credit Status -->
                        <div class="credit-status-grid">
                            <div class="credit-box credit-completed">
                                <div class="d-flex flex-row gap-1 align-items-baseline justify-content-center">
                                    <div class="credit-number">135</div>
                                    <div class="credit-unit">tín chỉ</div>
                                </div>
                                <div class="credit-label">Đã hoàn thành</div>
                            </div>
                            <div class="credit-box credit-remaining">
                                <div class="d-flex flex-row gap-1 align-items-baseline justify-content-center">
                                    <div class="credit-number">12</div>
                                    <div class="credit-unit">tín chỉ</div>
                                </div>
                                <div class="credit-label">Còn lại</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Current Status Section -->
                <div class="current-status-section">
                    <h6 class="status-title">Trạng thái học phần hiện tại</h6>

                    <div class="status-badge-row">
                        <div class="">
                            <span class="status-badge badge-open">ĐANG MỞ</span>
                        </div>
                        <div class="semester-info-open">
                            <span class="semester-info-status fw-semibold">
                                Học kỳ 2 (2024-2025)
                            </span>
                            <div class="deadline-text">Đến 20/02/2025</div>
                        </div>
                    </div>

                    <div class="registration-summary">
                        <div class="summary-row">
                            <span class="summary-label">Đã đăng ký:</span>
                            <span class="summary-value">3 / 12 TC</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Tối đa:</span>
                            <span class="summary-value">24 TC</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Scholarship -->
        <div class="card border-0">
            <div class="card-header">
                <span class="card-title">Thông tin học bổng</span>
                <select class="form-select semester-select-dropdown"
                        id="semester-select">
                    <option value="HK1 (2025 - 2026)">HK1 (2025 - 2026)</option>
                    <option value="HK2 (2025 - 2026)">HK2 (2025 - 2026)</option>
                </select>
            </div>
            <div class="card-body">
                <div class="scholarship-list h-100 d-flex flex-column gap-3">
                    <div class="scholarship-item scholarship-approved">
                        <div class="scholarship-header">
                            <div class="scholarship-name">
                                Học bổng khuyến khích học tập
                            </div>
                            <span class="scholarship-status status-approved">
                                <i class="fas fa-check-circle"></i>
                                Đã duyệt
                            </span>
                        </div>
                        <div class="scholarship-details">
                            <div class="scholarship-amount-approved">70% học phí</div>
                            <div class="scholarship-semester">HK1 2024-2025</div>
                        </div>
                        <div class="scholarship-date">Ngày duyệt: 15/01/2025</div>
                    </div>
                    <div class="scholarship-item scholarship-pending">
                        <div class="scholarship-header">
                            <div class="scholarship-name">Học bổng tài năng CNTT</div>
                            <span class="scholarship-status status-pending">
                                <i class="fas fa-clock"></i> Đang xét duyệt
                            </span>
                        </div>
                        <div class="scholarship-details">
                            <div class="scholarship-amount-pending">5.000.000 VNĐ</div>
                            <div class="scholarship-semester">HK2 2024-2025</div>
                        </div>
                        <div class="scholarship-date">Ngày đăng ký: 02/02/2025</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="section-3 section-info">
        <div class="chart-container">
            <div class="chart-header">
                <span class="card-title">Kết quả học tập theo học kỳ</span>
                <select class="form-select grades-select-dropdown"
                        id="gradesSelect">
                    <option value="4">Thang điểm 4</option>
                    <option value="10">Thang điểm 10</option>
                </select>
            </div>

            <div class="chart-wrapper">
                <div class="gpa-chart" id="gpaChart"></div>
            </div>
        </div>

        <div>
            <div class="course-card">
                <div class="chart-header">
                    <span class="card-title">Lớp học phần học kỳ</span>

                    <select class="form-select semester-select-dropdown"
                            id="semesterSelect">
                        <option>HK1 (2025-2026)</option>
                        <option>HK2 (2025-2026)</option>
                    </select>
                </div>

                <!-- List LHP -->
                <div class="course-list-wrapper">
                    <div id="courseList"></div>
                </div>
            </div>
        </div>
    </section>
</div>


@section scripts {
    <script src="~/Scripts/js/dashboard.js"></script>
}