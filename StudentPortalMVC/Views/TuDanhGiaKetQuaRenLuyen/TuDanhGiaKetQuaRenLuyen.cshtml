@{
  ViewBag.Title = "Tự đánh giá kết quả rèn luyện";
}

@section styles{
    <link rel="stylesheet" href="~/Content/css/tu-danh-gia-ket-qua-ren-luyen.css" />
}

<div class="container-lg pt-4 mb-4">
    <!-- Main Content -->
    <div class="header-section">
        <div class="header-title">
            Tự đánh giá kết quả rèn luyện
        </div>
        <div class="header-subtitle">
            Đánh giá điểm rèn luyện của học kỳ
        </div>
    </div>
    <div class="grade-main">
        <div class="semesterSelect">
            <div class="d-flex align-items-center gap-2">
                <span class="semester-label">Học kỳ</span>
                <select class="form-select" id="semesterSelect">
                    <option value="HK1 (2025-2026)">
                        HK1 (2025 - 2026)
                    </option>
                    <option value="HK2 (2024-2025)">
                        HK2 (2024 - 2025)
                    </option>
                    <option value="HK1 (2024-2025)">
                        HK1 (2024 - 2025)
                    </option>
                </select>
            </div>
            <div>
                <button class="btn-print">
                    <i class="fa-solid fa-print"></i>
                </button>
            </div>
        </div>
        <div class="table-section">
            <div class="table-wrapper">
                <table class="detail-table table-hover">
                    <thead>
                        <tr style="background: var(--table-header-bg);">
                            <th>STT</th>
                            <th>NỘI DUNG VÀ TIÊU CHÍ ĐÁNH GIÁ</th>
                            <th>ĐIỂM TỐI THIỂU</th>
                            <th>ĐIỂM TỐI ĐA</th>
                            <th>
                                SINH VIÊN VIẾT VẮN TẮT <br />
                                TỰ NHẬN XÉT VỀ KẾT QUẢ THỰC HIỆN
                            </th>
                            <th>ĐIỂM TỰ ĐÁNH GIÁ</th>
                            <th>FILE NỘP</th>
                            <th>KQRL CVHT/ <br />GVCN XÁC NHẬN</th>
                            <th>KQRL KHOA <br />XÁC NHẬN</th>
                            <th>
                                KQRL P.CTSV <br />
                                XÁC NHẬN
                            </th>
                        </tr>
                        <tr class="total-row">
                            <td class="total-label-sticky" colspan="2"
                                style="padding-left: 20px">
                                TỔNG ĐIỂM
                            </td>
                            <td colspan="3"></td>
                            <td>0,00</td>
                            <td></td>
                            <td>15,00</td>
                            <td>15,00</td>
                            <td>15,00</td>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
        <div class="d-flex justify-content-end">
            <button class="btn-confirm">Xác nhận</button>
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/js/tu-danh-gia-ket-qua-ren-luyen.js"></script>
}