@{
    ViewBag.Title = "Đề xuất xét tốt nghiệp";
}

@section styles{
    <link rel="stylesheet" href="~/Content/css/de-xuat-xet-tot-nghiep.css" />
}
<div class="container-lg pt-4">
    <!-- Page Header -->
    <div class="header-section">
        <div class="header-title">Đề xuất xét tốt nghiệp</div>
        <div class="header-subtitle">
            Đề xuất và xem kết quả đề xuất xét tốt nghiệp
        </div>
    </div>

