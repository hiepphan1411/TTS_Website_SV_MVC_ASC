    <div class="section-card">
        <div class="section-title">ĐỢT XÉT TỐT NGHIỆP</div>

        <div class="alert-warning mb-3">
            <i class="bi bi-exclamation-circle-fill"
               style="font-size: 18px"></i>
            <span>
                Ghi chú: Hiện đang có đợt đề xuất tốt nghiệp. Thực
                hiện xét thử và đề xuất
            </span>
        </div>

        <div class="btn-group-actions">
            <button class="btn-propose">Đề xuất xét TN</button>
            <button class="btn-cancel">Hủy đề xuất</button>
        </div>
    </div>

